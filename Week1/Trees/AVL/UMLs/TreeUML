    class Tree {
        <<Abstract>>
        +root()
        +parent(p)
        +num_children(p)
        +is_root(p)
        +depth(p)
    }

    class BinaryTree {
        <<Abstract>>
        +left(p)
        +right(p)
        +sibling(p)
    }

    class LinkedBinaryTree {
        -root
        -size
        +_add_root(e)
        +_add_left(p, e)
        #_validate(p)
    }

    class MapBase {
        <<Abstract>>
    }

    class Item {
        +_key
        +_value
    }

    class TreeMap {
        +_Item : alias to MapBase.Item
        +__getitem__(k)
        +__setitem__(k, v)
        #_subtree_search(p, k)
    }

    Tree <|-- BinaryTree
    BinaryTree <|-- LinkedBinaryTree
    MapBase <|-- TreeMap
    LinkedBinaryTree <|-- TreeMap
    MapBase *-- Item : contiene
    
    %% Classi Interne (Nested)
    Tree *-- Tree_Position : Position
    LinkedBinaryTree *-- Node : _Node
    TreeMap *-- TreeMap_Position : Position

    class Tree_Position {
        <<Interface>>
        +element()
    }
    
    class Node {
        -element
        -parent
        -left
        -right
    }

    class TreeMap_Position {
        +key()
        +value()
    }


